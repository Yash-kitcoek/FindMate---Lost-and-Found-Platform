<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<%
const lostItem = match.sourceType === 'LostItem' ? match.sourceItemId : match.matchedItemId;
const foundItem = match.sourceType === 'FoundItem' ? match.sourceItemId : match.matchedItemId;
const normalizeText = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, ' ');
const lostName = normalizeText(lostItem && lostItem.itemName);
const foundName = normalizeText(foundItem && foundItem.itemName);
const tokenizeText = (value) => normalizeText(value).split(' ').filter(Boolean);
const jaccardSimilarity = (left, right) => {
  const leftSet = new Set(tokenizeText(left));
  const rightSet = new Set(tokenizeText(right));
  if (!leftSet.size && !rightSet.size) return 1;
  if (!leftSet.size || !rightSet.size) return 0;
  let intersection = 0;
  leftSet.forEach((token) => {
    if (rightSet.has(token)) intersection += 1;
  });
  const union = new Set([...leftSet, ...rightSet]).size;
  return union ? intersection / union : 0;
};
const lostDescription = lostItem && lostItem.description ? lostItem.description : '';
const foundDescription = foundItem && foundItem.description ? foundItem.description : '';
const storedNameSimilarity = match.matchingFactors.itemNameSimilarity || 0;
const displayNameSimilarity = storedNameSimilarity > 0 ? storedNameSimilarity : (lostName && lostName === foundName ? 1 : 0);
const storedDescriptionSimilarity = match.matchingFactors.descriptionSimilarity || 0;
const recalculatedDescriptionSimilarity = jaccardSimilarity(lostDescription, foundDescription);
const displayDescriptionSimilarity = displayNameSimilarity === 1
  ? Math.max(storedDescriptionSimilarity, recalculatedDescriptionSimilarity)
  : storedDescriptionSimilarity;
const storedObjectTypeMatch = match.matchingFactors.objectTypeMatch;
const displayObjectTypeMatch = displayNameSimilarity === 1
  ? 1
  : (storedObjectTypeMatch !== undefined && storedObjectTypeMatch !== null
      ? storedObjectTypeMatch
      : 0.5);
const lostDate = lostItem && lostItem.lostDate ? new Date(lostItem.lostDate) : null;
const foundDate = foundItem && foundItem.foundDate ? new Date(foundItem.foundDate) : null;
let displayDateProximity = match.matchingFactors.dateProximity || 0;
if (lostDate && foundDate && !Number.isNaN(lostDate) && !Number.isNaN(foundDate) && displayDateProximity === 0) {
  const daysApart = Math.abs(lostDate - foundDate) / (1000 * 60 * 60 * 24);
  displayDateProximity = daysApart === 0 ? 1 : Math.max(0.05, Math.min(1, 1 / (1 + Math.pow(daysApart / 45, 1.6))));
}
const confidenceTone = match.confidenceScore >= 0.85
  ? 'is-high'
  : match.confidenceScore >= 0.65
    ? 'is-medium'
    : 'is-low';
const canContact = match.status === 'verified';
%>

<style>
  .match-review-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(34, 197, 94, 0.10), transparent 28%),
      radial-gradient(circle at top right, rgba(6, 182, 212, 0.08), transparent 24%),
      linear-gradient(180deg, #f5fbfb 0%, #ffffff 42%);
  }

  .match-review-container {
    width: min(1500px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0 48px;
  }

  .match-review-topbar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }

  .match-review-title {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2rem, 2vw + 1.25rem, 2.8rem);
    line-height: 1.05;
    color: #0f172a;
  }

  .match-review-subtitle {
    margin: 10px 0 0;
    max-width: 640px;
    color: #475569;
    font-size: 1rem;
    line-height: 1.6;
  }

  .match-review-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    color: #0f766e;
    font-weight: 700;
    text-decoration: none;
  }

  .match-review-link:hover {
    color: #115e59;
  }

  .match-review-link svg,
  .review-action-card svg {
    flex-shrink: 0;
  }

  .review-summary-card,
  .review-metric-card,
  .review-item-card,
  .review-actions-card,
  .review-help-card {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
  }

  .review-summary-card {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 320px;
    padding: 18px 20px;
  }

  .review-summary-orb {
    width: 66px;
    height: 66px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0891b2, #22c55e);
    color: #ffffff;
    font-size: 1.05rem;
    font-weight: 800;
  }

  .review-eyebrow {
    margin: 0 0 6px;
    color: #64748b;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .review-summary-score {
    margin: 0;
    color: #0f172a;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }

  .review-status-pill {
    display: inline-flex;
    align-items: center;
    margin-top: 10px;
    padding: 7px 12px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 0.84rem;
    font-weight: 800;
    text-transform: capitalize;
  }

  .review-status-pill.is-high {
    color: #166534;
    background: #dcfce7;
    border-color: #bbf7d0;
  }

  .review-status-pill.is-medium {
    color: #a16207;
    background: #fef3c7;
    border-color: #fde68a;
  }

  .review-status-pill.is-low {
    color: #be123c;
    background: #ffe4e6;
    border-color: #fecdd3;
  }

  .review-metrics-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .review-metric-card {
    padding: 18px;
  }

  .review-metric-value {
    margin: 10px 0 0;
    color: #0f172a;
    font-size: 1.85rem;
    font-weight: 800;
    line-height: 1;
  }

  .review-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 320px;
    gap: 20px;
    align-items: start;
  }

  .review-item-card {
    overflow: hidden;
  }

  .review-item-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 24px 18px;
    border-bottom: 1px solid #edf2f7;
  }

  .review-item-title {
    margin: 0;
    color: #0f172a;
    font-family: 'Poppins', sans-serif;
    font-size: 1.8rem;
    line-height: 1.12;
  }

  .review-item-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 0.82rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .review-item-badge.lost {
    color: #be123c;
    background: #ffe4e6;
  }

  .review-item-badge.found {
    color: #15803d;
    background: #dcfce7;
  }

  .review-item-body {
    padding: 24px;
  }

  .review-item-media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 8px;
    background: linear-gradient(135deg, #ecfeff, #f0fdf4);
    margin-bottom: 20px;
  }

  .review-item-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .review-item-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .review-field-label {
    margin: 0 0 6px;
    color: #64748b;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .review-field-value {
    margin: 0;
    color: #111827;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    overflow-wrap: anywhere;
  }

  .review-description {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #edf2f7;
  }

  .review-description p {
    margin: 10px 0 0;
    color: #475569;
    line-height: 1.7;
  }

  .review-contact-box {
    margin-top: 22px;
    padding: 18px;
    border-radius: 8px;
  }

  .review-contact-box.lost {
    background: #fff1f2;
    border: 1px solid #ffe4e6;
  }

  .review-contact-box.found {
    background: #ecfdf5;
    border: 1px solid #d1fae5;
  }

  .review-contact-box p {
    margin: 6px 0 0;
    color: #475569;
  }

  .review-contact-name {
    margin: 0;
    color: #0f172a;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .review-sidebar {
    display: grid;
    gap: 16px;
    position: sticky;
    top: 24px;
  }

  .review-actions-card,
  .review-help-card {
    padding: 20px;
  }

  .review-action-list {
    display: grid;
    gap: 12px;
    margin-top: 14px;
  }

  .review-action-card {
    width: 100%;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    padding: 16px 18px;
    border-radius: 8px;
    border: 1px solid #d1d5db;
    text-align: left;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    cursor: pointer;
  }

  .review-action-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 24px rgba(15, 23, 42, 0.08);
  }

  .review-action-card:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .review-action-card.verify {
    color: #ffffff;
    border-color: #16a34a;
    background: #16a34a;
  }

  .review-action-card.verify:hover {
    background: #15803d;
    border-color: #15803d;
  }

  .review-action-card.reject {
    color: #be123c;
    border-color: #fecaca;
    background: #fff1f2;
  }

  .review-action-card.reject:hover {
    border-color: #fda4af;
  }

  .review-action-card.contact {
    color: #ffffff;
    border-color: #0891b2;
    background: #0891b2;
  }

  .review-action-card.contact:hover {
    border-color: #0e7490;
    background: #0e7490;
  }

  .review-action-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 800;
  }

  .review-action-text {
    margin: 6px 0 0;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .review-action-card.verify .review-action-text {
    color: #dcfce7;
  }

  .review-action-card.reject .review-action-text {
    color: #e11d48;
  }

  .review-action-card.contact .review-action-text {
    color: #cffafe;
  }

  .review-dashboard-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px 16px;
    border-radius: 8px;
    border: 1px solid #d1d5db;
    background: #ffffff;
    color: #374151;
    font-weight: 700;
    text-decoration: none;
  }

  .review-dashboard-link:hover {
    background: #f8fafc;
  }

  .review-help-card p {
    margin: 0;
    color: #475569;
    line-height: 1.7;
  }

  @media (max-width: 1199px) {
    .review-metrics-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .review-layout {
      grid-template-columns: 1fr;
    }

    .review-sidebar {
      position: static;
    }
  }

  @media (max-width: 767px) {
    .match-review-container {
      width: min(100% - 24px, 100%);
      padding: 24px 0 40px;
    }

    .match-review-topbar {
      flex-direction: column;
      align-items: stretch;
    }

    .review-summary-card {
      min-width: 0;
    }

    .review-metrics-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .review-item-head,
    .review-item-body,
    .review-actions-card,
    .review-help-card {
      padding: 18px;
    }

    .review-item-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="match-review-page">
  <div class="match-review-container">
    <div class="match-review-topbar">
      <div>
        <a href="/admin/matches" class="match-review-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Matches
        </a>
        <h1 class="match-review-title">Match Review</h1>
        <p class="match-review-subtitle">Compare both reports, check the evidence, and decide whether this pair should move forward as a confirmed match.</p>
      </div>

      <div class="review-summary-card">
        <div class="review-summary-orb"><%= Math.round(match.confidenceScore * 100) %></div>
        <div>
          <p class="review-eyebrow">Confidence Score</p>
          <p class="review-summary-score"><%= (match.confidenceScore * 100).toFixed(1) %>%</p>
          <span class="review-status-pill <%= confidenceTone %>"><%= match.status.replace('_', ' ') %></span>
        </div>
      </div>
    </div>

    <div class="review-metrics-grid">
      <div class="review-metric-card">
        <p class="review-eyebrow">Category</p>
        <p class="review-metric-value"><%= (match.matchingFactors.categoryMatch * 100).toFixed(0) %>%</p>
      </div>
      <div class="review-metric-card">
        <p class="review-eyebrow">Description</p>
        <p class="review-metric-value"><%= (displayDescriptionSimilarity * 100).toFixed(0) %>%</p>
      </div>
      <div class="review-metric-card">
        <p class="review-eyebrow">Item Name</p>
        <p class="review-metric-value"><%= (displayNameSimilarity * 100).toFixed(0) %>%</p>
      </div>
      <div class="review-metric-card">
        <p class="review-eyebrow">Object Type</p>
        <p class="review-metric-value"><%= (displayObjectTypeMatch * 100).toFixed(0) %>%</p>
      </div>
      <div class="review-metric-card">
        <p class="review-eyebrow">Location</p>
        <p class="review-metric-value"><%= (match.matchingFactors.locationProximity * 100).toFixed(0) %>%</p>
      </div>
      <div class="review-metric-card">
        <p class="review-eyebrow">Date</p>
        <p class="review-metric-value"><%= (displayDateProximity * 100).toFixed(0) %>%</p>
      </div>
    </div>

    <div class="review-layout">
      <section class="review-item-card">
        <div class="review-item-head">
          <div>
            <p class="review-eyebrow">Lost Report</p>
            <h2 class="review-item-title"><%= lostItem.itemName %></h2>
          </div>
          <span class="review-item-badge lost">Lost Item</span>
        </div>

        <div class="review-item-body">
          <% if (lostItem.photoUrl) { %>
            <div class="review-item-media">
              <img src="<%= lostItem.photoUrl %>" alt="Lost item">
            </div>
          <% } %>

          <div class="review-item-grid">
            <div>
              <p class="review-field-label">Category</p>
              <p class="review-field-value"><%= lostItem.category %></p>
            </div>
            <div>
              <p class="review-field-label">Lost Location</p>
              <p class="review-field-value"><%= lostItem.lostLocation %></p>
            </div>
            <div>
              <p class="review-field-label">Lost Date</p>
              <p class="review-field-value"><%= new Date(lostItem.lostDate).toLocaleDateString() %></p>
            </div>
            <% if (lostItem.color) { %>
              <div>
                <p class="review-field-label">Color</p>
                <p class="review-field-value"><%= lostItem.color %></p>
              </div>
            <% } %>
            <% if (lostItem.brand) { %>
              <div>
                <p class="review-field-label">Brand</p>
                <p class="review-field-value"><%= lostItem.brand %></p>
              </div>
            <% } %>
          </div>

          <div class="review-description">
            <p class="review-field-label">Description</p>
            <p><%= lostItem.description %></p>
          </div>

          <div class="review-contact-box lost">
            <p class="review-eyebrow">Reporter</p>
            <p class="review-contact-name"><%= lostItem.user.fullName %></p>
            <p><%= lostItem.user.email %></p>
            <% if (lostItem.user.phone) { %>
              <p><%= lostItem.user.phone %></p>
            <% } %>
          </div>
        </div>
      </section>

      <section class="review-item-card">
        <div class="review-item-head">
          <div>
            <p class="review-eyebrow">Found Report</p>
            <h2 class="review-item-title"><%= foundItem.itemName %></h2>
          </div>
          <span class="review-item-badge found">Found Item</span>
        </div>

        <div class="review-item-body">
          <% if (foundItem.photoUrl) { %>
            <div class="review-item-media">
              <img src="<%= foundItem.photoUrl %>" alt="Found item">
            </div>
          <% } %>

          <div class="review-item-grid">
            <div>
              <p class="review-field-label">Category</p>
              <p class="review-field-value"><%= foundItem.category %></p>
            </div>
            <div>
              <p class="review-field-label">Found Location</p>
              <p class="review-field-value"><%= foundItem.foundLocation %></p>
            </div>
            <div>
              <p class="review-field-label">Found Date</p>
              <p class="review-field-value"><%= new Date(foundItem.foundDate).toLocaleDateString() %></p>
            </div>
            <div>
              <p class="review-field-label">Current Location</p>
              <p class="review-field-value"><%= foundItem.currentLocation %></p>
            </div>
            <div>
              <p class="review-field-label">Contact Phone</p>
              <p class="review-field-value"><%= foundItem.contactPhone %></p>
            </div>
          </div>

          <div class="review-description">
            <p class="review-field-label">Description</p>
            <p><%= foundItem.description %></p>
          </div>

          <div class="review-contact-box found">
            <p class="review-eyebrow">Finder</p>
            <p class="review-contact-name"><%= foundItem.finder.fullName %></p>
            <p><%= foundItem.finder.email %></p>
            <% if (foundItem.finder.phone) { %>
              <p><%= foundItem.finder.phone %></p>
            <% } %>
          </div>
        </div>
      </section>

      <aside class="review-sidebar">
        <div class="review-actions-card">
          <p class="review-eyebrow">Review Actions</p>
          <div class="review-action-list">
            <button onclick="verifyMatch()" class="review-action-card verify" type="button">
              <div>
                <p class="review-action-title">Verify Match</p>
                <p class="review-action-text">Mark both reports as confirmed and move them into the verified flow.</p>
              </div>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </button>

            <button onclick="rejectMatch()" class="review-action-card reject" type="button">
              <div>
                <p class="review-action-title">Reject Match</p>
                <p class="review-action-text">Store the reason and keep these reports from being treated as the same item.</p>
              </div>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>

            <button onclick="contactUsers()" class="review-action-card contact" type="button" <%= canContact ? '' : 'disabled' %>>
              <div>
                <p class="review-action-title">Contact Both Users</p>
                <p class="review-action-text"><%= canContact ? 'Send the verified handoff details to both users.' : 'Verify the match first to unlock contact sharing.' %></p>
              </div>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </button>
          </div>
        </div>

        <div class="review-help-card">
          <p class="review-eyebrow">Quick Read</p>
          <p>Strong matches usually line up on item name, object type, and location. Use the description and date signal to decide whether the handoff should proceed now or wait for more evidence.</p>
        </div>

        <a href="/admin/dashboard" class="review-dashboard-link">Back to Dashboard</a>
      </aside>
    </div>
  </div>
</div>

<script>
  async function verifyMatch() {
    if (!confirm('Are you sure you want to verify this match? This will update both items to matched status.')) return;

    try {
      const res = await fetch('/admin/matches/<%= match._id %>/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      const data = await res.json();

      if (data.success) {
        alert('Success: ' + data.message);
        window.location.href = '/admin/matches?status=verified';
      } else {
        alert('Error: ' + data.error);
      }
    } catch (error) {
      alert('Error: ' + error.message);
    }
  }

  async function rejectMatch() {
    const reason = prompt('Please provide a reason for rejection:');
    if (!reason) return;

    try {
      const res = await fetch('/admin/matches/<%= match._id %>/reject', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason })
      });

      const data = await res.json();

      if (data.success) {
        alert('Success: Match rejected.');
        window.location.href = '/admin/matches?status=rejected';
      } else {
        alert('Error: ' + data.error);
      }
    } catch (error) {
      alert('Error: ' + error.message);
    }
  }

  async function contactUsers() {
    if (!confirm('Send contact information to both users via email?')) return;

    try {
      const res = await fetch('/admin/matches/<%= match._id %>/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      const data = await res.json();

      if (data.success) {
        alert('Success: ' + data.message);
      } else {
        alert('Error: ' + data.error);
      }
    } catch (error) {
      alert('Error: ' + error.message);
    }
  }
</script>

<%- include('../partials/footer') %>
